{
  "name": "mcp-lab-agent",
  "version": "1.1.1",
  "description": "MCP server + AI agents for QA automation in any project (Cypress, Playwright, Jest)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-lab-agent": "dist/index.js"
  },
  "files": [
    "dist",
    "qa-lab-flows.json.example"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:report": "vitest run --reporter=default --reporter=json --outputFile=test-results/results.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "qa",
    "testing",
    "cypress",
    "playwright",
    "jest",
    "cursor",
    "ai-agent",
    "test-automation",
    "self-healing",
    "qa-metrics"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Wesley-Gomes93/mcp-lab-agent"
  },
  "author": "Wesley Gomes",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^16.4.5",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.0",
    "tsup": "^8.3.5",
    "typescript": "^5",
    "vitest": "^2.1.0"
  }
}
