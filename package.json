{
  "name": "mcp-lab-agent",
  "version": "2.3.0",
  "description": "Sistema de Inteligência em Qualidade de Software: executa, analisa, prevê, recomenda e aprende. Memória local + Learning Hub.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-lab-agent": "dist/index.js"
  },
  "files": [
    "dist",
    "learning-hub",
    "slack-bot",
    "qa-lab-agent.config.json",
    "qa-lab-flows.json.example"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "slack-bot": "node slack-bot/src/index.js",
    "slack-bot:check": "node slack-bot/check-config.js",
    "learning-hub": "node learning-hub/src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:report": "vitest run --reporter=default --reporter=json --outputFile=test-results/results.json",
    "resume:html": "node curriculos/generate-pdf.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "qa",
    "testing",
    "cypress",
    "playwright",
    "jest",
    "cursor",
    "ai-agent",
    "test-automation",
    "self-healing",
    "qa-metrics",
    "autonomous-agent",
    "self-learning",
    "auto-correction",
    "flaky-detection"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wesley-Gomes93/mcp-lab-agent.git"
  },
  "author": "Wesley Gomes",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@slack/bolt": "^3.21.0",
    "dotenv": "^16.4.5",
    "zod": "^3.25.0"
  },
  "optionalDependencies": {
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.0",
    "tsup": "^8.3.5",
    "typescript": "^5",
    "vitest": "^2.1.0"
  }
}
