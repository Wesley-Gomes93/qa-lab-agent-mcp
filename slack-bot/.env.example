# Copie para .env e preencha

# Slack (api.slack.com/apps → sua app)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# LLM (para mcp-lab-agent usar nos jobs)
# GROQ_API_KEY=...
# GEMINI_API_KEY=...
# ou QA_LAB_LLM_BASE_URL= e QA_LAB_LLM_API_KEY=

# Onde clonar repos (opcional)
# CLONE_BASE_DIR=/tmp/qa-lab-clones

# Porta do servidor (opcional)
# PORT=3000
