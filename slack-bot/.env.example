# === OBRIGATÓRIO (pegue em api.slack.com/apps) ===
SLACK_BOT_TOKEN=xoxb-...

# Escolha UM modo (funciona em qualquer ambiente):
# A) Socket Mode — recomendado. Não precisa de URL pública (pessoal, corporativo, firewall)
#    Basic Information → App-Level Tokens → Generate (scope: connections:write)
SLACK_APP_TOKEN=xapp-...

# B) HTTP — precisa de ngrok. Event Subscriptions → Request URL
# SLACK_SIGNING_SECRET=...

# === REPO (se não configurou no qa-lab-agent.config.json) ===
# REPO_URL=https://github.com/sua-empresa/projeto.git
# REPO_BRANCH=main

# === LLM (opcional - só para "crie testes") ===
# GROQ_API_KEY=...

# === AVANÇADO: caminho customizado do .env ===
# QA_LAB_ENV=/caminho/para/.env
